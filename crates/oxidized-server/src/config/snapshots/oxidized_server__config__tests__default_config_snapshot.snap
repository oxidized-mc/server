---
source: crates/oxidized-server/src/config/mod.rs
expression: toml_str
---
[network]
port = 25565
ip = ""
is_online_mode = true
is_preventing_proxy_connections = false
compression_threshold = 256
rate_limit = 0
is_accepting_transfers = false

[network.timeouts]
keepalive_interval_secs = 15
keepalive_timeout_secs = 30
login_timeout_secs = 30
configuration_timeout_secs = 30
write_timeout_secs = 30

[network.connection_rate_limit]
max_connections_per_window = 10
window_secs = 10
cleanup_interval_secs = 60

[gameplay]
gamemode = "survival"
difficulty = "easy"
is_hardcore = false
is_force_gamemode = false
max_players = 20
spawn_protection = 16
